{
  "name": "batch-video-watermark-master",
  "version": "0.1.0",
  "private": true,
  "description": "Local batch video watermark remover and sticker cover desktop app.",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1\" \"tsc -p tsconfig.main.json --watch\" \"wait-on http://127.0.0.1:5273 dist/main/main.js && electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "worker:check": "python3 -m py_compile worker/main.py worker/video_info.py worker/processors.py worker/sticker.py"
  },
  "dependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "electron": "^32.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0",
    "typescript": "^5.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {}
}
